@inject BlogApi Api

<div class="comments">
    <h3>Comments</h3>

    <div class="new-comment">
        <textarea class="comment-input"
                  @bind="_newComment"
                  @bind:event="oninput"
                  maxlength="@ContentLimits.MaxCommentLength"
                  rows="3"
                  placeholder="Add a comment…"></textarea>
        <div class="comment-form-row">
            <span class="muted">@_newComment.Length / @ContentLimits.MaxCommentLength</span>
            <button class="btn btn-primary btn-sm" @onclick="AddComment" disabled="@_posting">Comment</button>
        </div>
        @if (_error is not null)
        {
            <div class="field-error">@_error</div>
        }
    </div>

    @if (_loading && _comments.Count == 0)
    {
        <p class="muted">Loading comments…</p>
    }
    else if (_comments.Count == 0)
    {
        <p class="muted">No comments yet. Start the conversation!</p>
    }
    else
    {
        <div class="comment-tree">
            @foreach (var comment in _comments)
            {
                <CommentNode @key="comment.Id" Comment="comment" ArticleId="ArticleId" />
            }
        </div>
    }

    @if (_hasMore)
    {
        <button class="btn btn-secondary btn-sm show-more" @onclick="LoadMore" disabled="@_loading">
            @(_loading ? "Loading…" : "Show more comments")
        </button>
    }
</div>

@code {
    [Parameter] public Guid ArticleId { get; set; }

    private readonly List<CommentDto> _comments = new();
    private int _page;
    private bool _hasMore;
    private bool _loading;
    private bool _posting;
    private string _newComment = "";
    private string? _error;

    // Loads the first page when the section is opened ("Show comments").
    protected override Task OnInitializedAsync() => LoadFirstPageAsync();

    private async Task LoadFirstPageAsync()
    {
        _comments.Clear();
        _page = 0;
        _hasMore = false;
        await LoadMore();
    }

    // Appends the next page ("Show more comments").
    private async Task LoadMore()
    {
        _loading = true;
        try
        {
            var result = await Api.GetCommentsAsync(ArticleId, _page + 1);
            _comments.AddRange(result.Items);
            _page = result.Page;
            _hasMore = result.HasMore;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddComment()
    {
        var content = _newComment.Trim();
        _error = null;
        if (content.Length == 0)
        {
            _error = "Comment cannot be empty.";
            return;
        }

        _posting = true;
        try
        {
            await Api.AddCommentAsync(ArticleId, new CreateCommentRequest { Content = content });
            _newComment = "";
            // Reload from the first page so the new (newest) comment is visible.
            await LoadFirstPageAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _posting = false;
        }
    }
}
