@inject BlogApi Api
@inject UserState User

<div class="comment @(_comment.IsDeleted ? "comment-deleted" : null)">
    <div class="comment-head">
        <strong class="comment-author">@(_comment.IsDeleted ? "—" : _comment.Author)</strong>
        <span class="comment-time">@_comment.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
        @if (_comment is { IsDeleted: false, UpdatedAt: not null })
        {
            <span class="comment-edited">(edited)</span>
        }
    </div>

    @if (_comment.IsDeleted)
    {
        <div class="comment-body deleted-text">This comment was deleted</div>
    }
    else if (_editing)
    {
        <textarea class="comment-input"
                  @bind="_editText"
                  @bind:event="oninput"
                  maxlength="@ContentLimits.MaxCommentLength"
                  rows="3"></textarea>
        <div class="comment-form-row">
            <span class="muted">@_editText.Length / @ContentLimits.MaxCommentLength</span>
            <span>
                <button class="btn btn-primary btn-sm" @onclick="SaveEdit" disabled="@_busy">Save</button>
                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit" disabled="@_busy">Cancel</button>
            </span>
        </div>
    }
    else
    {
        <div class="comment-body">@_comment.Content</div>
    }

    @if (_error is not null)
    {
        <div class="field-error">@_error</div>
    }

    @if (!_editing)
    {
        <div class="comment-actions">
            <button class="link-btn" @onclick="ToggleReply">Reply</button>
            @if (!_comment.IsDeleted && User.Owns(_comment.Author))
            {
                <button class="link-btn" @onclick="StartEdit">Edit</button>
                @if (!_confirmingDelete)
                {
                    <button class="link-btn danger" @onclick="() => _confirmingDelete = true">Delete</button>
                }
                else
                {
                    <span class="confirm">
                        Delete?
                        <button class="link-btn danger" @onclick="DeleteComment" disabled="@_busy">Yes</button>
                        <button class="link-btn" @onclick="() => _confirmingDelete = false" disabled="@_busy">No</button>
                    </span>
                }
            }
        </div>
    }

    @if (_replying)
    {
        <div class="reply-box">
            <textarea class="comment-input"
                      @bind="_replyText"
                      @bind:event="oninput"
                      maxlength="@ContentLimits.MaxCommentLength"
                      rows="2"
                      placeholder="Write a reply…"></textarea>
            <div class="comment-form-row">
                <span class="muted">@_replyText.Length / @ContentLimits.MaxCommentLength</span>
                <span>
                    <button class="btn btn-primary btn-sm" @onclick="SubmitReply" disabled="@_busy">Reply</button>
                    <button class="btn btn-secondary btn-sm" @onclick="ToggleReply" disabled="@_busy">Cancel</button>
                </span>
            </div>
        </div>
    }

    @if (_replies.Count > 0)
    {
        <div class="replies">
            @foreach (var reply in _replies)
            {
                <CommentNode @key="reply.Id" Comment="reply" ArticleId="ArticleId" />
            }
        </div>
    }

    <div class="replies-controls">
        @if (!_repliesLoaded && _comment.ReplyCount > 0)
        {
            <button class="link-btn" @onclick="LoadReplies" disabled="@_loadingReplies">
                @(_loadingReplies ? "Loading…" : $"Show replies ({_comment.ReplyCount})")
            </button>
        }
        else if (_repliesHasMore)
        {
            <button class="link-btn" @onclick="LoadReplies" disabled="@_loadingReplies">
                @(_loadingReplies ? "Loading…" : "Show more replies")
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public CommentDto Comment { get; set; } = default!;
    [Parameter] public Guid ArticleId { get; set; }

    // Authoritative local copy so the node's own edits/deletes/replies survive
    // re-renders triggered by the parent (which keeps loading more pages above us).
    private CommentDto _comment = default!;

    private readonly List<CommentDto> _replies = new();
    private int _repliesPage;
    private bool _repliesLoaded;
    private bool _repliesHasMore;
    private bool _loadingReplies;

    private bool _replying;
    private bool _editing;
    private bool _confirmingDelete;
    private bool _busy;
    private string _replyText = "";
    private string _editText = "";
    private string? _error;

    protected override void OnParametersSet()
    {
        // Re-sync only when this slot is (re)assigned to a different comment;
        // never clobber our own in-place edits with the original parameter.
        if (_comment is null || _comment.Id != Comment.Id)
            _comment = Comment;
    }

    // "Show replies" (first page) and "Show more replies" (next page) both append.
    private async Task LoadReplies()
    {
        _loadingReplies = true;
        try
        {
            var result = await Api.GetRepliesAsync(_comment.Id, _repliesPage + 1);
            _replies.AddRange(result.Items);
            _repliesPage = result.Page;
            _repliesHasMore = result.HasMore;
            _repliesLoaded = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loadingReplies = false;
        }
    }

    private void ToggleReply()
    {
        _replying = !_replying;
        _replyText = "";
        _error = null;
    }

    private void StartEdit()
    {
        _editing = true;
        _editText = _comment.Content;
        _error = null;
    }

    private void CancelEdit()
    {
        _editing = false;
        _error = null;
    }

    private async Task SubmitReply()
    {
        var content = _replyText.Trim();
        _error = null;
        if (content.Length == 0)
        {
            _error = "Reply cannot be empty.";
            return;
        }

        _busy = true;
        try
        {
            await Api.AddCommentAsync(ArticleId, new CreateCommentRequest
            {
                Content = content,
                ParentCommentId = _comment.Id,
            });
            _replying = false;
            _replyText = "";
            _comment = _comment with { ReplyCount = _comment.ReplyCount + 1 };
            // Reload replies from the first page so the new (newest) reply shows.
            _replies.Clear();
            _repliesPage = 0;
            _repliesLoaded = false;
            _repliesHasMore = false;
            await LoadReplies();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveEdit()
    {
        var content = _editText.Trim();
        _error = null;
        if (content.Length == 0)
        {
            _error = "Comment cannot be empty.";
            return;
        }

        _busy = true;
        try
        {
            var updated = await Api.UpdateCommentAsync(_comment.Id, new UpdateCommentRequest { Content = content });
            _comment = updated with { ReplyCount = _comment.ReplyCount };
            _editing = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteComment()
    {
        _busy = true;
        _error = null;
        try
        {
            var deleted = await Api.DeleteCommentAsync(_comment.Id);
            _comment = deleted with { ReplyCount = _comment.ReplyCount };
            _confirmingDelete = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
